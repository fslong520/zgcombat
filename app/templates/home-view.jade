extends /templates/base-flat

block content
  .container
    .row
      .col-lg-12.text-center(style="padding: 60px 0 30px")
        h1(data-i18n="new_home.slogan")
        p.lead.text-muted(style="font-size:18px;margin-top:10px", data-i18n="new_home.meta_description_coco")
        div(style="margin: 30px 0")
          a.btn.btn-success.btn-lg(href="/play", style="margin:5px;min-width:180px", data-i18n="common.play") Play
          a.btn.btn-primary.btn-lg(href="/students", style="margin:5px;min-width:180px", data-i18n="nav.my_courses") My Courses
          a.btn.btn-navy.btn-lg(href="/teachers/classes", style="margin:5px;min-width:180px", data-i18n="nav.my_classrooms") My Classrooms
          a.btn.btn-warning.btn-lg(href="/editor/level", style="margin:5px;min-width:180px", data-i18n="editor.level_editor") Level Editor
    .row#learn-more-row
      .col-xs-12.text-center
        a#learn-more-link
          h6(data-i18n="new_home.learn_more")
          h2: span.glyphicon.glyphicon-chevron-down
    .row(style="margin-top:40px")
      .col-sm-4.text-center
        img(src="/images/pages/home/F1_typedcode.png", style="width:120px;height:120px", alt="")
        h4(data-i18n="new_home.real_code")
        p.small(data-i18n="new_home.getting_students")
      .col-sm-4.text-center
        img(src="/images/pages/home/F2_teacherguides.png", style="width:120px;height:120px", alt="")
        h4(data-i18n="new_home.educator_resources")
        p.small(data-i18n="new_home.teaching_computer_science")
      .col-sm-4.text-center
        img(src="/images/pages/home/F3_accessible.png", style="width:120px;height:120px", alt="")
        h4(data-i18n="new_home.accessible_to")
        p.small(data-i18n="new_home.democratizing")